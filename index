// Sub-Kuis: Menjodohkan
const MatchQuiz = ({ showToast }) => {
  const [leftItems, setLeftItems] = useState([]);
  const [rightItems, setRightItems] = useState([]);
  const [selLeft, setSelLeft] = useState(null);
  const [selRight, setSelRight] = useState(null);
  const [matchedIds, setMatchedIds] = useState([]);

  useEffect(() => {
    setLeftItems(shuffleArray(matchQuizData));
    setRightItems(shuffleArray(matchQuizAns));
  }, []);

  const handleSelectLeft = (item) => {
    if (matchedIds.includes(item.id)) return;
    setSelLeft(item);
    checkMatch(item, selRight);
  };

  const handleSelectRight = (item) => {
    if (matchedIds.includes(item.id)) return;
    setSelRight(item);
    checkMatch(selLeft, item);
  };

  const checkMatch = (left, right) => {
    if (left && right) {
      if (left.id === right.id) {
        showToast('Cocok! Hebat! 😻');
        setMatchedIds([...matchedIds, left.id]);
        setSelLeft(null);
        setSelRight(null);
      } else {
        showToast('Tetot! Kurang tepat 😿');
        setSelLeft(null);
        setSelRight(null);
      }
    }
  };

  return (
    <div>
      <p className="mb-4 text-pink-700 bg-pink-50 p-3 rounded-lg">Pilih kata bahasa Jepang di sebelah kiri dan artinya di sebelah kanan!</p>
      <div className="flex gap-4">
        {/* Kolom Kiri */}
        <div className="flex-1 flex flex-col gap-2">
          {leftItems.map(item => (
            <button 
              key={item.id} 
              onClick={() => handleSelectLeft(item)}
              className={`p-3 rounded-xl font-bold transition-colors ${matchedIds.includes(item.id) ? 'bg-green-200 text-green-800 opacity-50' : selLeft?.id === item.id ? 'bg-pink-500 text-white' : 'bg-pink-100 text-pink-800 hover:bg-pink-200'}`}
              disabled={matchedIds.includes(item.id)}
            >
              {item.jp}
            </button>
          ))}
        </div>
        {/* Kolom Kanan */}
        <div className="flex-1 flex flex-col gap-2">
          {rightItems.map(item => (
            <button 
              key={item.id} 
              onClick={() => handleSelectRight(item)}
              className={`p-3 rounded-xl font-bold transition-colors ${matchedIds.includes(item.id) ? 'bg-green-200 text-green-800 opacity-50' : selRight?.id === item.id ? 'bg-blue-500 text-white' : 'bg-blue-100 text-blue-800 hover:bg-blue-200'}`}
              disabled={matchedIds.includes(item.id)}
            >
              {item.arti}
            </button>
          ))}
        </div>
      </div>
      {matchedIds.length === 10 && <div className="mt-6 text-center text-2xl text-pink-600 font-bold bg-pink-100 p-4 rounded-xl">Luar Biasa! Semua Berhasil Dijodohkan! 🎉</div>}
    </div>
  );
};

// Sub-Kuis: Susun Kalimat
const SusunQuiz = ({ showToast }) => {
  const [qIndex, setQIndex] = useState(0);
  const [words, setWords] = useState([]);
  const [answers, setAnswers] = useState([]);

  const currentQ = susunData[qIndex];

  useEffect(() => {
    if (currentQ) {
      setWords(shuffleArray(currentQ.words));
      setAnswers([]);
    }
  }, [qIndex, currentQ]);

  const addWord = (w, i) => {
    setAnswers([...answers, w]);
    setWords(words.filter((_, index) => index !== i));
  };

  const removeWord = (w, i) => {
    setWords([...words, w]);
    setAnswers(answers.filter((_, index) => index !== i));
  };

  const checkAnswer = () => {
    if (answers.join('') === currentQ.correct) {
      showToast('Tepat sekali! Nya~ 😺');
      setTimeout(() => {
        if (qIndex < susunData.length - 1) setQIndex(qIndex + 1);
        else showToast('Selesai! Kamu jago menyusun kalimat! 🎉');
      }, 1000);
    } else {
      showToast('Susunannya belum pas meow, coba lagi! 😿');
      // Reset
      setWords(shuffleArray(currentQ.words));
      setAnswers([]);
    }
  };

  if (qIndex >= susunData.length) return <div className="text-center p-8 bg-pink-100 rounded-xl text-2xl font-bold text-pink-600">Selamat! Kuis Susun Kalimat Selesai! 🌸</div>;

  return (
    <div className="bg-pink-50 p-6 rounded-2xl">
      <div className="mb-2 text-pink-500 font-bold">Soal {qIndex + 1} / 5</div>
      <p className="text-pink-800 mb-6 italic">" {currentQ.arti} "</p>
      
      {/* Kotak Jawaban */}
      <div className="min-h-[60px] bg-white border-2 border-dashed border-pink-400 rounded-xl p-3 flex flex-wrap gap-2 mb-6 items-center">
        {answers.length === 0 && <span className="text-gray-400">Klik kata di bawah untuk menyusun...</span>}
        {answers.map((w, i) => (
          <button key={i} onClick={() => removeWord(w, i)} className="bg-pink-400 text-white px-4 py-2 rounded-lg font-bold hover:bg-pink-500">
            {w}
          </button>
        ))}
      </div>

      {/* Pilihan Kata */}
      <div className="flex flex-wrap gap-2 mb-6">
        {words.map((w, i) => (
          <button key={i} onClick={() => addWord(w, i)} className="bg-white border-2 border-pink-300 text-pink-700 px-4 py-2 rounded-lg font-bold hover:bg-pink-100 shadow-sm">
            {w}
          </button>
        ))}
      </div>

      <button onClick={checkAnswer} className="w-full bg-pink-500 text-white py-3 rounded-xl font-bold hover:bg-pink-600 shadow-md">
        Cek Jawaban 🐾
      </button>
    </div>
  );
};

