// --- GAME TAB: MEMORY CARD MATCHER ---
const GameTab = ({ showToast }) => {
  const [cards, setCards] = useState([]);
  const [flipped, setFlipped] = useState([]);
  const [solved, setSolved] = useState([]);
  const [awaitingInput, setAwaitingInput] = useState(false);
  const [matchData, setMatchData] = useState(null);
  const [inputValue, setInputValue] = useState('');

  // Setup game
  useEffect(() => {
    startNewGame();
  }, []);

  const startNewGame = () => {
    // Ambil 8 pasang dari data Kanji (total 16 kartu)
    const selected = shuffleArray(kanjiData).slice(0, 8);
    let gameCards = [];
    selected.forEach(k => {
      gameCards.push({ ...k, id: Math.random() });
      gameCards.push({ ...k, id: Math.random() });
    });
    setCards(shuffleArray(gameCards));
    setFlipped([]);
    setSolved([]);
    setAwaitingInput(false);
    setMatchData(null);
  };

  const handleCardClick = (index) => {
    if (awaitingInput || flipped.length === 2 || flipped.includes(index) || solved.includes(index)) return;
    
    const newFlipped = [...flipped, index];
    setFlipped(newFlipped);

    if (newFlipped.length === 2) {
      const card1 = cards[newFlipped[0]];
      const card2 = cards[newFlipped[1]];
      
      if (card1.kanji === card2.kanji) {
        // MATCH! Tanya hiragana/arti
        setTimeout(() => {
          setMatchData(card1);
          setAwaitingInput(true);
        }, 500);
      } else {
        // No Match
        setTimeout(() => setFlipped([]), 1000);
      }
    }
  };

  const handleSubmit = (e) => {
    e.preventDefault();
    const ans = inputValue.toLowerCase().trim();
    // Validasi: kunyomi bisa ada titik (ex: おも.う), bersihkan titiknya. 
    const cleanKunyomi = matchData.kunyomi.replace('.', '');
    
    if (ans === cleanKunyomi || ans === matchData.meaning.toLowerCase()) {
      showToast('Benar sekali! Nyaaa~ 😻');
      setSolved([...solved, ...flipped]);
    } else {
      showToast(`Salah meow! 😿 Jawaban yang benar: ${cleanKunyomi} atau ${matchData.meaning}`);
    }
    
    setFlipped([]);
    setAwaitingInput(false);
    setMatchData(null);
    setInputValue('');
  };

  return (
    <div className="bg-white p-6 rounded-3xl shadow-lg border-4 border-pink-200">
      <div className="flex justify-between items-center mb-6">
        <h2 className="text-3xl font-bold text-pink-600 flex items-center gap-2">
          🃏 Game Memori & Tebak Kanji
        </h2>
        <button onClick={startNewGame} className="bg-pink-400 text-white px-4 py-2 rounded-xl font-bold hover:bg-pink-500 shadow-md">
          Mulai Ulang 🔄
        </button>
      </div>
      
      <p className="text-pink-700 mb-6 bg-pink-50 p-4 rounded-xl">
        Cari dua kartu berpasangan. Kalau sama, Neko-sensei akan meminta kamu menebak hiragana (cara baca kunyomi) atau arti dari kanji tersebut!
      </p>

      {/* Grid Kartu */}
      <div className="grid grid-cols-4 gap-4 mb-8">
        {cards.map((c, i) => {
          const isFlipped = flipped.includes(i) || solved.includes(i);
          return (
            <div 
              key={c.id} 
              onClick={() => handleCardClick(i)}
              className={`h-24 md:h-32 flex items-center justify-center text-4xl md:text-5xl font-serif rounded-2xl cursor-pointer transition-all duration-300 transform ${isFlipped ? 'bg-pink-100 text-pink-600 border-2 border-pink-400 shadow-inner' : 'bg-pink-300 text-transparent hover:bg-pink-400 shadow-md'}`}
            >
              {isFlipped ? c.kanji : '🐾'}
            </div>
          )
        })}
      </div>

      {solved.length === 16 && (
        <div className="text-center p-6 bg-pink-100 rounded-2xl border-2 border-pink-400 mb-4 animate-bounce text-2xl font-bold text-pink-600">
          🎉 SELAMAT! KAMU MENANG NYAA~ 🎉
        </div>
      )}

      {/* Modal / Dialog Input */}
      {awaitingInput && (
        <div className="fixed inset-0 bg-pink-900 bg-opacity-50 flex items-center justify-center z-50 p-4">
          <div className="bg-white p-8 rounded-3xl max-w-sm w-full shadow-2xl text-center border-4 border-pink-400">
            <div className="text-6xl mb-4 text-pink-500">{matchData.kanji}</div>
            <p className="font-bold text-pink-700 mb-4">Kartu cocok! Ketik bacaan Hiragana (tanpa titik) atau Artinya:</p>
            <form onSubmit={handleSubmit}>
              <input 
                type="text"
                autoFocus
                className="w-full p-3 border-2 border-pink-300 rounded-xl mb-4 focus:outline-none focus:border-pink-500 text-center text-xl"
                placeholder="cth: warui / buruk"
                value={inputValue}
                onChange={(e) => setInputValue(e.target.value)}
              />
              <button type="submit" className="w-full bg-pink-500 text-white font-bold py-3 rounded-xl hover:bg-pink-600 shadow-md">
                Jawab 🐾
              </button>
            </form>
          </div>
        </div>
      )}
    </div>
  );
};

